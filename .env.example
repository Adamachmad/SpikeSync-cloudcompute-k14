APP_NAME="VolleyTrack SaaS"
APP_ENV=local
APP_KEY=base64:+IHNJaFKpShvwLYNwvXQ7pWC3/EJSpYEO8CPh8uNLIM=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

## Database Configuration
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=volleytrack_db
DB_USERNAME=volleytrack_user
DB_PASSWORD=volleytrack_password

## Cache Configuration
CACHE_DRIVER=file
CACHE_STORE=file

## Queue Configuration
QUEUE_CONNECTION=sync

## Session Configuration
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

## Mail Configuration
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@volleytrack.test"
MAIL_FROM_NAME="${APP_NAME}"

## AWS Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

## Third Party API Configuration
EXERCISE_DB_API_KEY=your_exercise_db_api_key_here
EXERCISE_DB_API_URL=https://exercisedb.p.rapidapi.com
SPORTS_API_KEY=your_sports_api_key_here
SPORTS_API_URL=https://api.api-sports.io

## Application Configuration
PRICING_BASIC_PRICE=29900
PRICING_PRO_PRICE=99900
TRIAL_DAYS=7

## Redis Configuration (Optional)
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

## Sanctum Configuration
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:8000
SANCTUM_EXPIRATION=525600
